# Copy this file to ".env" and fill in your values from:
# Supabase Dashboard → Project Settings → API
#
# The VITE_ prefix is REQUIRED — Vite only exposes vars starting with VITE_
# to the browser. The anon key is safe to expose; Row Level Security
# protects your data.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key
